# Diese Datei kopieren, in .local.env umbenennen und nur lokal ausfüllen.
APP_STORE_ISSUER_ID=
APP_STORE_KEY_ID=
APP_STORE_PRIVATE_KEY_PATH=.secrets/AuthKey_LuckyTest.p8
APP_STORE_APP_ID=
APP_STORE_BUNDLE_ID=

# OAuth-Client vom Typ "Desktop-App" aus der Google Cloud Console.
YOUTUBE_OAUTH_CLIENT_PATH=.secrets/youtube_oauth_client.json
YOUTUBE_TOKEN_PATH=.secrets/youtube_token.json

# TikTok Developer Sandbox mit Login Kit (Desktop).
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://127.0.0.1:3456/callback/
TIKTOK_TOKEN_PATH=.secrets/tiktok_token.json

# Instagram API with Instagram Login (Business Login).
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://localhost:3457/callback/
INSTAGRAM_TOKEN_PATH=.secrets/instagram_token.json
INSTAGRAM_CERTIFICATE_PATH=.secrets/instagram_localhost_cert.pem
INSTAGRAM_PRIVATE_KEY_PATH=.secrets/instagram_localhost_key.pem
INSTAGRAM_API_VERSION=v25.0

